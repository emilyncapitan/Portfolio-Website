#include <SoftwareSerial.h>

// SIM900 RX, TX
SoftwareSerial SIM900(9, 10);

bool gsmReady = false;

// -------------------- SETUP --------------------
void setup() {
  Serial.begin(9600);
  SIM900.begin(9600);

  Serial.println("Initializing SIM900A...");

  unsigned long startTime = millis();

  while (!gsmReady && millis() - startTime < 10000) {
    SIM900.println("AT");
    delay(1000);

    if (SIM900.find("OK")) {
      gsmReady = true;
    }
  }

  if (!gsmReady) {
    Serial.println("ERROR: SIM900A not responding");
    return;
  }

  Serial.println("SIM900A READY");

  // Set SMS text mode
  SIM900.println("AT+CMGF=1");
  delay(500);

  Serial.println("================================");
  Serial.println("SEND SMS FORMAT:");
  Serial.println("09222102016,Hello from SIM900A");
  Serial.println("================================");
}

// -------------------- LOOP --------------------
void loop() {
  if (Serial.available()) {
    String input = Serial.readStringUntil('\n');
    input.trim();

    int commaIndex = input.indexOf(',');

    if (commaIndex > 0) {
      String number = input.substring(0, commaIndex);
      String message = input.substring(commaIndex + 1);

      number = formatPHNumber(number);

      sendSMS(number, message);
    } else {
      Serial.println("Invalid format! Use: number,message");
    }
  }

  if (SIM900.available()) {
    Serial.write(SIM900.read());
  }
}

// -------------------- SEND SMS --------------------
void sendSMS(String number, String message) {
  Serial.println("Sending SMS to:");
  Serial.println(number);

  SIM900.print("AT+CMGS=\"");
  SIM900.print(number);
  SIM900.println("\"");
  delay(1000);  // wait for '>'

  SIM900.print(message);
  delay(500);

  SIM900.write(26);  // CTRL+Z
  delay(3000);

  Serial.println("SMS SENT ✔");
}

// -------------------- NUMBER FORMATTER --------------------
String formatPHNumber(String num) {
  num.replace(" ", "");
  num.replace("-", "");

  if (num.startsWith("09")) {
    num = "+63" + num.substring(1);
  }

  return num;
}
